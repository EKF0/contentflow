    "@trpc/next": "^11.13.0",
    "@trpc/react-query": "^11.13.0",
    "@trpc/server": "^11.13.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.44.1",
    "next": "14.2.29",
    "openai": "^4.96.0",
    "postgres": "^3.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^6.12.4",
    "svix": "^1.24.0",
    "tailwind-merge": "^3.0.2",
    "zod": "^3.25.76"
