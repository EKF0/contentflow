    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/lib/db/seed.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.12.12",
    "@supabase/supabase-js": "^2.49.4",
    "@tanstack/react-query": "^5.101.0",
